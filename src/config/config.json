---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import FeaturedVideos from '@components/FeaturedVideos.astro';
import HomePagination from '@components/HomePagination.astro';
---

<BaseLayout>
  <div class="hidden">
    <Hero />
  </div>

  <div class="hidden">
    <FeaturedVideos />
  </div>

  <main class="mx-auto max-w-screen-lg px-4 font-sans text-zinc-700 dark:text-zinc-300 sm:px-6 lg:px-8">
    <HomePagination />
  </main>
</BaseLayout>
